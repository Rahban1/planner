# OpenCode Go API key (required for the agent runner)
LLM_API_KEY=sk-...

# OpenCode Go model and base URL (defaults shown)
# NOTE: kimi-k2.7-code currently returns "Upstream request failed" via OpenCode Go.
# Using kimi-k2.6 until that model is restored.
LLM_MODEL=openai/kimi-k2.6
LLM_API_BASE=https://opencode.ai/zen/go/v1

# GitHub personal access token for the agent to push branches and create PRs
GITHUB_TOKEN=ghp_...

# URL the runner uses to reach the planner dev server.
# Docker Desktop Mac users: if host.docker.internal does not route to localhost,
# use the host's LAN IP (e.g. http://192.168.1.22:3000) instead.
PLANNER_BASE_URL=http://host.docker.internal:3000
